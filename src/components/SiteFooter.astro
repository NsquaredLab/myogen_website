---
import { Image } from "astro:assets";
import logo from "../assets/myogen_logo.png";
---

<footer class="site">
  <div class="container">
    <div class="foot-grid">
      <div class="foot-col">
        <div class="foot-brand-row">
          <Image src={logo} alt="MyoGen" class="foot-logo" width={44} /><span
            class="foot-brand">MyoGen</span>
        </div>
        <div class="foot-brand-desc">
          A modular, NEURON-backed simulation toolkit for human neuromuscular
          activity and EMG generation. A joint project of the Nsquared Lab
          (Neuromuscular Physiology and Neural Interfacing Laboratory) at FAU
          Erlangen-Nürnberg, the NER Lab (Neural Engineering Research
          Laboratory) at the University of Campinas, and the BMClab
          (Biomechanics and Motor Control Laboratory) at the Federal University
          of ABC.
        </div>
      </div>
      <div class="foot-col">
        <h5>Project</h5>
        <ul>
          <li>
            <a href="https://nsquaredlab.github.io/MyoGen/">Documentation</a>
          </li>
          <li><a href="https://github.com/NsquaredLab/MyoGen">GitHub</a></li>
          <li><a target="_self" href="#governance">Governance</a></li>
          <li><a target="_self" href="#citation">Citation</a></li>
          <li>
            <a href="https://www.gnu.org/licenses/agpl-3.0.html"
              >License (AGPL-3.0)</a>
          </li>
        </ul>
      </div>
      <div class="foot-col">
        <h5>Research</h5>
        <ul>
          <li>
            <a href="https://www.biorxiv.org/content/10.64898/2026.01.01.697284"
              >Manuscript</a
            >
          </li>
          <li>
            <a href="https://doi.org/10.5281/zenodo.18078175">Zenodo archive</a>
          </li>
          <li><a target="_self" href="#validation">Validation suite</a></li>
          <li>
            <a href="https://nsquaredlab.github.io/MyoGen/examples.html"
              >Examples</a>
          </li>
        </ul>
      </div>
      <div class="foot-col">
        <h5>Labs</h5>
        <ul>
          <li>
            <a href="https://nsquared.tf.fau.de/"
              >Nsquared Lab (Neuromuscular Physiology and Neural Interfacing) ↗</a>
          </li>
          <li>
            <a
              href="https://www.ceb.unicamp.br/pesquisa/laboratorios/laboratorio-de-pesquisa-em-neuroengenharia/"
              >NER Lab (Neural Engineering Research) ↗</a>
          </li>
          <li>
            <a href="https://bmclab.pesquisa.ufabc.edu.br/"
              >BMClab (Biomechanics and Motor Control) ↗</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span
        >© 2026 Nsquared Lab (FAU Erlangen-Nürnberg), NER Lab (Unicamp) &amp;
        BMClab (UFABC) · <a
          href="https://www.gnu.org/licenses/agpl-3.0.html">AGPL-3.0</a
        ></span
      >
      <span
        ><a href="https://doi.org/10.64898/2026.01.01.697284"
          >doi:10.64898/2026.01.01.697284</a
        ></span
      >
    </div>
  </div>
</footer>
